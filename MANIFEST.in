# Bundled xterm.js assets (fallback for non-Debian installs; Debian uses the
# system libjs-xterm and excludes this directory from the binary package).
recursive-include src/sshpilot/vendor/pyxtermjs/xterm *
recursive-include src/sshpilot/resources *
# Blueprint sources are build-time inputs (compiled to .ui, bundled in the
# gresource); never ship them.
recursive-exclude src/sshpilot/resources *.blp
recursive-include src/sshpilot/plugins/builtin *.json
# Example plugins are dev references only — keep them out of the sdist/wheel.
prune src/sshpilot/plugins/examples
