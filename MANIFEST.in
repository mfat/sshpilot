include sshpilot/vendor/pyxtermjs/*.html
include sshpilot/vendor/pyxtermjs/LICENSE
# Bundled xterm.js assets (fallback for non-Debian installs; Debian uses the
# system libjs-xterm and excludes this directory from the binary package).
recursive-include sshpilot/vendor/pyxtermjs/xterm *
recursive-include sshpilot/resources *
recursive-include sshpilot/plugins/builtin *.json
# Example plugins are dev references only — keep them out of the sdist/wheel.
prune sshpilot/plugins/examples

