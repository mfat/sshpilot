#!/usr/bin/env python3
"""Local stand-in for the easyenv CLI (github.com/donedeploy/easyenv-cli).

Mirrors the real command surface and JSON shapes so the EasyEnv Workspaces
plugin can be demoed end to end with NO easyenv account, network, or real
binary. The SAME plugin drives this stub or the real `easyenv` depending on
which is first on PATH — pointing at the real binary (plus `easyenv auth
login`) is a drop-in.

State lives in a local JSON file (never touches the real ~/.config/easyenv/).
`machine ssh <m> -w <ws>` (and `workspace ssh <ws>`) exec a real interactive
shell, so the sshPilot terminal tab opens a genuinely working session.

Shapes match the real CLI: workspaces have uuid/title/status; a workspace's
machines come from `machine list -w <ws>` (and `workspace get` nests them under
`boxes`), each {uuid,title,status,host_address}. Templates may create multiple
machines (e.g. ansible-ubuntu-cluster -> control + 3 Ubuntu nodes).
"""

import json
import os
import sys
import time

VERSION = "0.5.0-stub"


def _machines_for(template, n_start):
    """Build a machine list for a template. cluster/ansible/kube templates
    create multiple nodes (with repeating titles, like the real API)."""
    t = (template or "").lower()
    if "ansible" in t:
        specs = [("Ansible Dev Env", "ubuntu"), ("Ubuntu 24.04 LTS", "ubuntu"),
                 ("Ubuntu 24.04 LTS", "ubuntu"), ("Ubuntu 24.04 LTS", "ubuntu")]
    elif "cluster" in t or "kube" in t:
        specs = [("Control Plane", "ubuntu"), ("Worker Node", "ubuntu"),
                 ("Worker Node", "ubuntu")]
    else:
        specs = [("Ubuntu 24.04 LTS", "ubuntu")]
    out = []
    for i, (title, recipe) in enumerate(specs):
        mid = f"m-{n_start:03d}{i}"
        out.append({"uuid": mid, "title": title, "status": "active",
                    "host_address": f"box-{mid}", "recipe": {"image_type": recipe}})
    return out


def _state_path():
    base = os.environ.get("XDG_STATE_HOME") or os.path.join(
        os.path.expanduser("~"), ".local", "state")
    return os.path.join(base, "easyenv-stub.json")


def _load():
    try:
        with open(_state_path(), "r", encoding="utf-8") as fh:
            return json.load(fh)
    except (OSError, ValueError):
        # Seed a logged-in account and a multi-node workspace so the plugin
        # shows a group immediately.
        return {
            "account": "demo@easyenv.io",
            "logged_in": True,
            "next_id": 2,
            "workspaces": [
                {"id": 1, "uuid": "ws-001", "title": "ansible-cluster",
                 "status": "active", "template": "ansible-ubuntu-cluster",
                 "machines": _machines_for("ansible-ubuntu-cluster", 1)},
            ],
        }


def _match(wss, arg):
    return next((w for w in wss
                 if arg in (w.get("uuid"), w.get("title"), str(w.get("id")))), None)


def _save(state):
    path = _state_path()
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as fh:
        json.dump(state, fh, indent=2)


def _opt(args, *names):
    for name in names:
        if name in args:
            i = args.index(name)
            if i + 1 < len(args):
                return args[i + 1]
    return None


def _has(args, *names):
    return any(n in args for n in names)


def _json_requested(args):
    return _opt(args, "--output", "-o") == "json"


def _emit(args, payload, human):
    if _json_requested(args):
        print(json.dumps(payload, indent=2))
    else:
        print(human)


def _exec_shell(banner):
    sys.stdout.write(banner)
    sys.stdout.flush()
    shell = os.environ.get("SHELL", "/bin/bash")
    os.execvp(shell, [shell, "-i"])


def main(argv):
    args = argv[1:]
    if not args or args[0] in ("--version", "version"):
        print(VERSION)
        return 0

    state = _load()
    group = args[0]
    rest = args[1:]
    wss = state["workspaces"]

    if group == "auth":
        sub = rest[0] if rest else ""
        if sub == "whoami":
            if state.get("logged_in"):
                print(f"User: {state.get('account')}")
                return 0
            print("Not logged in", file=sys.stderr)
            return 1
        if sub == "login":
            state["logged_in"] = True
            state["account"] = state.get("account") or "demo@easyenv.io"
            _save(state)
            print(f"Saved token for {state.get('account')}")
            return 0
        if sub == "logout":
            state["logged_in"] = False
            _save(state)
            print("Logged out")
            return 0
        if sub == "token":
            print("stub-token-xxxxxxxx")
            return 0

    if group == "account":
        sub = rest[0] if rest else ""
        if sub in ("list", "ls"):
            _emit(rest, [{"uuid": "acct-1", "title": state.get("account")}],
                  state.get("account", ""))
            return 0
        if sub == "use":
            print(f"Using account {rest[1] if len(rest) > 1 else ''}")
            return 0
        if sub == "current":
            print("acct-1")
            return 0

    if group in ("workspace", "ws", "w"):
        sub = rest[0] if rest else ""

        if sub in ("list", "ls"):
            view = [{"uuid": w["uuid"], "title": w["title"], "status": w["status"]}
                    for w in wss]
            _emit(rest, view,
                  "\n".join(f"{w['uuid']}  {w['title']}  {w['status']}" for w in wss))
            return 0

        if sub in ("get", "describe"):
            ws = _match(wss, rest[1] if len(rest) > 1 else "")
            if ws is None:
                print("workspace not found", file=sys.stderr)
                return 1
            detail = {"uuid": ws["uuid"], "title": ws["title"], "status": ws["status"],
                      "boxes": ws.get("machines", [])}
            _emit(rest, detail, json.dumps(detail))
            return 0

        if sub == "create":
            name = _opt(rest, "--name") or f"ws-{int(time.time())}"
            template = _opt(rest, "--template") or _opt(rest, "--base") or "custom"
            wsid = f"ws-{state['next_id']:03d}"
            ws = {"id": state["next_id"], "uuid": wsid, "title": name,
                  "status": "active", "template": template,
                  "machines": _machines_for(template, state["next_id"])}
            state["next_id"] += 1
            wss.append(ws)
            _save(state)
            _emit(rest, {"uuid": wsid, "title": name, "status": "active"},
                  f"Created {wsid} ({name}). {len(ws['machines'])} machine(s).")
            return 0

        if sub in ("start", "stop", "restart", "delete", "rm"):
            ws = _match(wss, rest[1] if len(rest) > 1 else "")
            if ws is None:
                print("workspace not found", file=sys.stderr)
                return 1
            if sub in ("delete", "rm"):
                wss.remove(ws)
            elif sub == "stop":
                ws["status"] = "stopped"
            else:
                ws["status"] = "active"
            _save(state)
            print(f"{sub} {ws['uuid']}: ok")
            return 0

        if sub == "ssh":  # workspace ssh <ws> -> first machine
            ws = _match(wss, rest[1] if len(rest) > 1 else "")
            label = ws["title"] if ws else (rest[1] if len(rest) > 1 else "?")
            _exec_shell(f"[easyenv-stub] connected to {label} (first machine) "
                        f"over mesh. Ctrl-D to exit.\n")

    if group in ("machine", "m"):
        sub = rest[0] if rest else ""
        ws = _match(wss, _opt(rest, "-w", "--workspace") or "")
        machines = ws.get("machines", []) if ws else []

        if sub in ("list", "ls"):
            _emit(rest, machines,
                  "\n".join(f"{m['uuid']}  {m['title']}  {m['status']}" for m in machines))
            return 0

        if sub == "ssh":
            marg = rest[1] if len(rest) > 1 else ""
            m = next((x for x in machines
                      if marg in (x.get("uuid"), x.get("title"))), None)
            label = (m["title"] if m else marg)
            if _has(rest, "--dry-run"):
                print(f"would ssh to {label} on workspace {ws['title'] if ws else '?'}")
                return 0
            _exec_shell(f"[easyenv-stub] connected to node '{label}' "
                        f"(workspace {ws['title'] if ws else '?'}) over mesh. "
                        f"Ctrl-D to exit.\n")

    print(f"easyenv-stub: unsupported command: {' '.join(args)}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv))
